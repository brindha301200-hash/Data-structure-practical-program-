 Searching Methods (Linear & Binary Search)
Program 
import time
# Product list
products = ["Laptop", "Mobile", "Tablet", "Camera", "Headphones"]
# Linear Search
def linear_search(arr, key):
    for i in range(len(arr)):
        if arr[i] == key:
            return i
    return -1

# Binary Search
def binary_search(arr, key):
    low = 0
    high = len(arr) - 1

    while low <= high:
        mid = (low + high) // 2

        if arr[mid] == key:
            return mid
        elif arr[mid] < key:
            low = mid + 1
        else:
            high = mid - 1
    return -1


key = input("Enter product to search: ")

# Linear Search Time
start = time.time()
result = linear_search(products, key)
end = time.time()

print("\nLinear Search")
if result != -1:
    print("Product found at position:", result)
else:
    print("Product not found")

print("Execution Time:", end - start)

# Binary Search (Sorted List)
products.sort()

start = time.time()
result = binary_search(products, key)
end = time.time()

print("\nBinary Search")
if result != -1:
    print("Product found at position:", result)
else:
    print("Product not found")

print("Execution Time:", end - start)
