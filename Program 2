Stack ADT Using Singly Linked List:
Program 
class Node:
    def __init__(self,data):
        self.data=data
        self.next=None

class Stack:
    def __init__(self):
        self.top=None

    def push(self,data):
        new=Node(data)
        new.next=self.top
        self.top=new
        print("Visited:",data)

    def pop(self):
        if self.top is None:
            print("No pages to go back")
        else:
            print("Back from:",self.top.data)
            self.top=self.top.next

    def display(self):
        temp=self.top
        print("Browsing History:")
        while temp:
            print(temp.data)
            temp=temp.next

s=Stack()

while True:
    print("\n1.Visit Page")
    print("2.Back")
    print("3.Display History")
    print("4.Exit")

    ch=int(input("Enter choice: "))

    if ch==1:
        page=input("Enter Webpage: ")
        s.push(page)

    elif ch==2:
        s.pop()

    elif ch==3:
        s.display()

    elif ch==4:
        break
