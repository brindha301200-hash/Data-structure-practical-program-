BFS and DFS (graph)
Program
from collections import deque
# Graph using adjacency list
graph = {}
# Add connection between users
def add_edge(u, v):
    graph.setdefault(u, []).append(v)
    graph.setdefault(v, []).append(u)
# BFS Traversal
def bfs(start):
    visited = set()
    queue = deque([start])
    visited.add(start)
    print("BFS (Shortest Friend Connections):")
    while queue:
        user = queue.popleft()
        print(user, end=" ")
        for friend in graph[user]:
            if friend not in visited:
                visited.add(friend)
                queue.append(friend)

# DFS Traversal
def dfs(user, visited):
    visited.add(user)
    print(user, end=" ")

    for friend in graph[user]:
        if friend not in visited:
            dfs(friend, visited)

# Main Program
add_edge("A", "B")
add_edge("A", "C")
add_edge("B", "D")
add_edge("C", "E")

start_user = "A"

bfs(start_user)

print("\nDFS (All Connected Users):")
visited = set()
dfs(start_user, visited)

Output
BFS (Shortest Friend Connections):
A B C D E

DFS (All Connected Users):
A B D C E
