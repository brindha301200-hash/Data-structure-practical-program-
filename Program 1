Program (Python)

students = []
while True:
    print("\n1.Insert Beginning")
    print("2.Insert End")
    print("3.Insert Position")
    print("4.Delete")
    print("5.Search")
    print("6.Display")
    print("7.Exit")

    ch = int(input("Enter Choice: "))

    if ch == 1:
        sid = int(input("Enter Student ID: "))
        name = input("Enter Name: ")
        marks = int(input("Enter Marks: "))
        students.insert(0,[sid,name,marks])

    elif ch == 2:
        sid = int(input("Enter Student ID: "))
        name = input("Enter Name: ")
        marks = int(input("Enter Marks: "))
        students.append([sid,name,marks])

    elif ch == 3:
        pos = int(input("Enter Position: "))
        sid = int(input("Enter Student ID: "))
        name = input("Enter Name: ")
        marks = int(input("Enter Marks: "))
        students.insert(pos-1,[sid,name,marks])

    elif ch == 4:
        sid = int(input("Enter ID to Delete: "))
        for s in students:
            if s[0] == sid:
                students.remove(s)
                print("Record Deleted")

    elif ch == 5:
        sid = int(input("Enter ID to Search: "))
        for s in students:
            if s[0] == sid:
                print("Record Found:",s)

    elif ch == 6:
        print("Student Records")
        for s in students:
            print("ID:",s[0],"Name:",s[1],"Marks:",s[2])

    elif ch == 7:
        break

