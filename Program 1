2️⃣ Implementation Using Singly Linked List

class Node:
    def __init__(self,sid,name,marks):
        self.sid=sid
        self.name=name
        self.marks=marks
        self.next=None

class StudentList:
    def __init__(self):
        self.head=None

    def insert_begin(self,sid,name,marks):
        new=Node(sid,name,marks)
        new.next=self.head
        self.head=new

    def insert_end(self,sid,name,marks):
        new=Node(sid,name,marks)
        if self.head is None:
            self.head=new
            return
        temp=self.head
        while temp.next:
            temp=temp.next
        temp.next=new

    def display(self):
        temp=self.head
        while temp:
            print(temp.sid,temp.name,temp.marks)
            temp=temp.next

    def search(self,sid):
        temp=self.head
        while temp:
            if temp.sid==sid:
                print("Record Found:",temp.sid,temp.name,temp.marks)
                return
            temp=temp.next
        print("Record Not Found")

    def delete(self,sid):
        temp=self.head
        prev=None
        while temp:
            if temp.sid==sid:
                if prev is None:
                    self.head=temp.next
                else:
                    prev.next=temp.next
                print("Record Deleted")
                return
            prev=temp
            temp=temp.next

s=StudentList()

while True:
    print("\n1.Insert Begin")
    print("2.Insert End")
    print("3.Delete")
    print("4.Search")
    print("5.Display")
    print("6.Exit")

    ch=int(input("Enter Choice: "))

    if ch==1:
        sid=int(input("Enter ID: "))
        name=input("Enter Name: ")
        marks=int(input("Enter Marks: "))
        s.insert_begin(sid,name,marks)

    elif ch==2:
        sid=int(input("Enter ID: "))
        name=input("Enter Name: ")
        marks=int(input("Enter Marks: "))
        s.insert_end(sid,name,marks)

    elif ch==3:
        sid=int(input("Enter ID to Delete: "))
        s.delete(sid)

    elif ch==4:
        sid=int(input("Enter ID to Search: "))
        s.search(sid)

    elif ch==5:
        s.display()

    elif ch==6:
        break

